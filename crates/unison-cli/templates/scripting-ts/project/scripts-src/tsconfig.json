{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "../assets/scripts",
    "strict": true,
    "esModuleInterop": true,
    "noEmitOnError": true,
    "types": []
  },
  "tstl": {
    "luaTarget": "5.4",
    "luaLibImport": "require",
    "luaBundle": "main.lua",
    "luaBundleEntry": "main.ts",
    "noImplicitSelf": true,
    "sourceMapTraceback": true
  },
  "include": [
    "**/*.ts",
    "types/**/*.d.ts",
    "../../node_modules/@typescript-to-lua/language-extensions/index.d.ts"
  ]
}
